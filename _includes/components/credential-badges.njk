{#
  Reusable Credential Badges Component
  Displays NJ HIC license, TCNA compliance, and review ratings
  Parameters:
    - class: Optional additional CSS classes (default: "")
    - style: Optional inline styles (default: "")
#}

{%- set hic = site.company.hic | default("13VH10808800") -%}

<div
  class="contractor-credentials{% if class %} {{ class }}{% endif %}"
  {% if style %}
  style="{{ style }}"
  {% endif %}
>
  <span class="badge badge--trust" title="Licensed NJ Contractor">NJ HIC #{{ hic }}</span>
  <span class="badge badge--compliance" title="TCNA Compliant">TCNA-Compliant Methods</span>
  <span class="badge badge--reviews" title="5-Star Reviews">★ 5.0 Google &amp; Thumbtack</span>
</div>
