<!doctype html>
<html lang="en" {% if html_attrs %} {{ html_attrs }}{% endif %}>
  <head>
    <title>
      {% if meta_title %}{{ meta_title | trim | e }}{% elif title %}{{ title | trim | e
      }} | {{ site.title | trim | e }}{% else %}{{ site.title | trim | e }}{% endif %}
    </title>
    {% include "layout/head.njk" %} {% include "schema/schema-combined.njk" %} {% include "layout/meta-open-graph.njk" %} {% include "layout/meta-geo.njk" %} {% include "layout/meta-canonical.njk" %} {% include "layout/meta-success-confetti.njk" %} {% if page.url == "/contact/" %}{% include "forms/contact-page.njk" %}{% endif
    %} {% if extra_head %}{{ extra_head }}{% endif %}
    <link rel="stylesheet" href="/assets/css/components/sticky-mobile-cta.css" />
  </head>
  <body
    class="ts-body{% if body_class %} {{ body_class }}{% endif %}{% if layout.body_class %} {{ layout.body_class }}{% endif %}{% if build_guide %} page-build-guide{% endif %}"
  >
    <nav class="skip-links" aria-label="Skip navigation">
      <a href="#main-content" class="skip-link">Skip to main content</a>
    </nav>
    <div class="ts-scroll-progress" aria-hidden="true" data-scroll-progress></div>
    {% include "header.njk" %} {% if show_breadcrumbs != false %}{% include "navigation/ts-breadcrumbs.njk" %}{%
    endif %}
    <main class="ts-main-content" id="main-content" aria-label="Main content">
      {{ body | default(content) }}
    </main>
    {% include "layout/footer.njk" %} {# Accessibility toolbar (all devices) #} {% include "components/a11y-toolbar.njk" %} {# Desktop-only features (too heavy for mobile) #}
    <div class="desktop-only-features">{% include "components/c-sticky-mobile-cta.njk" %}</div>

    {# Lead Magnet - Desktop Homepage only #} {% if is_home == true %}
    <div class="desktop-only-features">{% include "components/lead-magnet-popup.njk" %}</div>
    {% endif %} {% include "layout/scripts.njk" %}
    <script>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js').catch((err) => console.warn('[SW] Registration failed:', err));
        });
      }
    </script>
  </body>
</html>
