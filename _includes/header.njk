<header class="ts-header" id="site-header" aria-label="Main Header">
  <div class="ts-header__container">
    <div class="ts-header__branding">
      <a href="/" class="ts-header__logo-link" aria-label="Tillerstead LLC - Home">
        <img
          src="/assets/img/logo/logo-header@2x.webp?v={{ site.cache_version }}"
          alt="Tillerstead Logo"
          class="ts-header__logo"
          width="60"
          height="60"
          loading="eager"
          fetchpriority="high"
        />
      </a>
      <div class="ts-header__info">
        <span class="ts-header__company">Tillerstead LLC</span>
        <span class="ts-header__region">South Jersey • NJ HIC</span>
      </div>
    </div>
    {% include "navigation/ts-navigation.njk" %}
    <div class="ts-header__actions">
      <a href="tel:+16098628808" class="btn btn--ghost btn--sm" aria-label="Call Now">
        <svg class="btn-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.362 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.338 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        <span class="btn-text">Call Now</span>
      </a>
      <a href="/contact/" class="btn btn--primary btn--sm">Get Estimate</a>
    </div>
  </div>
</header>
