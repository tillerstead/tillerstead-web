{#
  ─────────────────────────────────────────────────────────────
  COMPONENT: Footer
  ─────────────────────────────────────────────────────────────
  DISPLAYS: Company info, navigation links, legal links
  TOKENS USED: --color-text-inverse, --color-brand-primary
  RESPONSIVE: Single column mobile, 4 columns on md+
─────────────────────────────────────────────────────────────
#}
<footer aria-label="Site footer" style="background-color: var(--color-surface-dark); color: var(--color-text-inverse);">
  <div class="mx-auto max-w-6xl px-6 py-16">
    
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-12">
      
      {# Company info #}
