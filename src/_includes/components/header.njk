{#
  ─────────────────────────────────────────────────────────────
  COMPONENT: Header Navigation (with mobile drawer)
  ─────────────────────────────────────────────────────────────
  DISPLAYS: Site logo, main navigation, CTA button, mobile hamburger
  TOKENS USED: --color-surface-primary, --color-text-*, --color-brand-primary
  RESPONSIVE: Hamburger drawer on mobile, inline nav on md+
─────────────────────────────────────────────────────────────
#}
<header class="sticky top-0 z-40 shadow-sm" style="background-color: var(--color-surface-primary); border-bottom: 1px solid var(--color-border-primary);">
  <div class="mx-auto max-w-6xl px-6 py-4">
    <div class="flex items-center justify-between gap-8">

      {# Logo #}
      <a href="/" class="flex items-center gap-3 shrink-0" aria-label="Tillerstead LLC">
        <div class="w-10 h-10 rounded-lg flex items-center justify-center text-white font-bold text-lg" style="background: linear-gradient(135deg, var(--color-brand-primary) 0%, var(--color-brand-primary-dark) 100%);">
          T
        </div>
        <div>
          <div class="font-semibold" style="color: var(--color-text-primary);">Tillerstead</div>
          <div class="text-xs" style="color: var(--color-text-tertiary);">LLC</div>
        </div>
      </a>

      {# Desktop Navigation #}
      <nav class="hidden md:flex items-center gap-8" aria-label="Main navigation">
        <ul class="flex items-center gap-8" role="list">
          <li><a href="/" class="nav-link text-sm font-medium transition-colors" style="color: var(--color-text-secondary);"{% if page.url == '/' %} aria-current="page"{% endif %}>Home</a></li>
          <li><a href="/services/" class="nav-link text-sm font-medium transition-colors" style="color: var(--color-text-secondary);"{% if page.url and page.url.indexOf('/services') === 0 %} aria-current="page"{% endif %}>Services</a></li>
          <li><a href="/guides/" class="nav-link text-sm font-medium transition-colors" style="color: var(--color-text-secondary);"{% if page.url and page.url.indexOf('/guides') === 0 %} aria-current="page"{% endif %}>Guides</a></li>
          <li><a href="/build/" class="nav-link text-sm font-medium transition-colors" style="color: var(--color-text-secondary);"{% if page.url and page.url.indexOf('/build') === 0 %} aria-current="page"{% endif %}>Build Phases</a></li>
          <li><a href="/contact/" class="nav-link text-sm font-medium transition-colors" style="color: var(--color-text-secondary);"{% if page.url == '/contact/' %} aria-current="page"{% endif %}>Contact</a></li>
        </ul>
      </nav>

      {# CTA + Hamburger #}
      <div class="flex items-center gap-4">
        <a href="/early-access/" class="hidden sm:inline-flex items-center gap-2 px-4 py-2 rounded-lg text-white text-sm font-medium transition-opacity hover:opacity-90" style="background-color: var(--color-brand-primary);">
          Early Access
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </a>

        {# Mobile hamburger button #}
        <button
          type="button"
          class="md:hidden flex items-center justify-center w-10 h-10 rounded-lg transition-colors"
          style="color: var(--color-text-primary);"
          aria-expanded="false"
          aria-controls="mobile-nav-drawer"
          aria-label="Open navigation menu"
          id="mobile-nav-toggle"
          onclick="const drawer=document.getElementById('mobile-nav-drawer');const isOpen=drawer.classList.toggle('is-open');this.setAttribute('aria-expanded',isOpen?'true':'false');drawer.setAttribute('aria-hidden',isOpen?'false':'true');if(isOpen){drawer.querySelector('a')?.focus();}else{this.focus();}"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>

    </div>
  </div>

  {# ── Mobile Navigation Drawer ── #}
  <div
    id="mobile-nav-drawer"
    class="mobile-nav-drawer md:hidden"
    aria-hidden="true"
    aria-label="Mobile navigation"
  >
    <nav class="flex flex-col gap-1 px-6 py-4" aria-label="Mobile navigation">
      <a href="/" class="block px-4 py-3 rounded-lg text-base font-medium transition-colors" style="color: var(--color-text-primary);"{% if page.url == '/' %} aria-current="page"{% endif %}>Home</a>
      <a href="/services/" class="block px-4 py-3 rounded-lg text-base font-medium transition-colors" style="color: var(--color-text-secondary);"{% if page.url and page.url.indexOf('/services') === 0 %} aria-current="page"{% endif %}>Services</a>
      <a href="/guides/" class="block px-4 py-3 rounded-lg text-base font-medium transition-colors" style="color: var(--color-text-secondary);"{% if page.url and page.url.indexOf('/guides') === 0 %} aria-current="page"{% endif %}>Guides</a>
      <a href="/build/" class="block px-4 py-3 rounded-lg text-base font-medium transition-colors" style="color: var(--color-text-secondary);"{% if page.url and page.url.indexOf('/build') === 0 %} aria-current="page"{% endif %}>Build Phases</a>
      <a href="/contact/" class="block px-4 py-3 rounded-lg text-base font-medium transition-colors" style="color: var(--color-text-secondary);"{% if page.url == '/contact/' %} aria-current="page"{% endif %}>Contact</a>
      <div class="mt-2 pt-2" style="border-top: 1px solid var(--color-border-primary);">
        <a href="/early-access/" class="block px-4 py-3 rounded-lg text-base font-medium text-white transition-opacity hover:opacity-90" style="background-color: var(--color-brand-primary); border-radius: 0.5rem;">
          Early Access
        </a>
      </div>
    </nav>
  </div>
</header>

{# ── Inline styles for mobile drawer (avoids extra CSS file) ── #}
<style>
  .mobile-nav-drawer {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease-out;
    background-color: var(--color-surface-primary);
    border-top: 1px solid var(--color-border-primary);
  }
  .mobile-nav-drawer.is-open {
    max-height: 500px;
  }
  .nav-link:hover,
  .nav-link:focus-visible {
    color: var(--color-text-primary) !important;
  }
  {# Active nav link styling #}
  [aria-current="page"] {
    color: var(--color-brand-primary) !important;
    font-weight: 600;
  }
</style>

{# ── Mobile drawer keyboard handler (Escape to close) ── #}
<script>
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
      var drawer = document.getElementById('mobile-nav-drawer');
      var toggle = document.getElementById('mobile-nav-toggle');
      if (drawer && drawer.classList.contains('is-open')) {
        drawer.classList.remove('is-open');
        drawer.setAttribute('aria-hidden', 'true');
        if (toggle) {
          toggle.setAttribute('aria-expanded', 'false');
          toggle.focus();
        }
      }
    }
  });
</script>
