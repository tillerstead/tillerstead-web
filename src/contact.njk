<section class="py-16 md:py-24" style="background-color: var(--color-surface-primary); border-bottom: 1px solid var(--color-border-primary);">
  <div class="mx-auto max-w-3xl px-6">
    <h1 class="text-4xl md:text-5xl font-bold mb-4" style="color: var(--color-text-primary);">Contact Us</h1>
    <p class="text-lg max-w-2xl" style="color: var(--color-text-secondary);">
      Ready to discuss your project? Reach out and we'll get back to you within one business day.
    </p>
  </div>
</section>

<section class="py-16 md:py-24" style="background-color: var(--color-surface-primary);">
  <div class="mx-auto max-w-3xl px-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">

      {# Contact methods #}
      <div>
        <h2 class="text-2xl font-bold mb-6" style="color: var(--color-text-primary);">Get in Touch</h2>
        
        <div class="space-y-6">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-lg flex items-center justify-center shrink-0" style="background-color: var(--color-brand-primary-tint); color: var(--color-brand-primary);">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
            </div>
            <div>
              <h3 class="font-semibold" style="color: var(--color-text-primary);">Email</h3>
              <a href="mailto:contact@tillerstead.com" class="hover:underline" style="color: var(--color-brand-primary);">contact@tillerstead.com</a>
              <p class="text-sm mt-1" style="color: var(--color-text-tertiary);">General inquiries and project estimates</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-lg flex items-center justify-center shrink-0" style="background-color: var(--color-brand-primary-tint); color: var(--color-brand-primary);">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
            </div>
            <div>
              <h3 class="font-semibold" style="color: var(--color-text-primary);">Phone</h3>
              <a href="tel:+16098628808" class="hover:underline" style="color: var(--color-brand-primary);">(609) 862-8808</a>
              <p class="text-sm mt-1" style="color: var(--color-text-tertiary);">Mon–Fri, 8am–5pm ET</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-lg flex items-center justify-center shrink-0" style="background-color: var(--color-brand-primary-tint); color: var(--color-brand-primary);">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
            </div>
            <div>
              <h3 class="font-semibold" style="color: var(--color-text-primary);">Service Area</h3>
              <p style="color: var(--color-text-primary);">Atlantic, Ocean, and Cape May Counties<br>South Jersey</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-lg flex items-center justify-center shrink-0" style="background-color: var(--color-brand-primary-tint); color: var(--color-brand-primary);">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
            </div>
            <div>
              <h3 class="font-semibold" style="color: var(--color-text-primary);">Licensing</h3>
              <p style="color: var(--color-text-primary);">NJ HIC# 13VH10808800</p>
              <p class="text-sm mt-1" style="color: var(--color-text-tertiary);">Licensed Home Improvement Contractor</p>
            </div>
          </div>
        </div>
      </div>

      {# Contact form #}
      <div>
        <h2 class="text-2xl font-bold mb-6" style="color: var(--color-text-primary);">Request an Estimate</h2>
        <form action="/api/contact" method="POST" class="space-y-5">
          <div>
            <label for="name" class="block text-sm font-medium mb-1" style="color: var(--color-text-primary);">Name</label>
            <input type="text" id="name" name="name" required class="form-input w-full px-4 py-2.5 rounded-lg border transition-colors" autocomplete="name" />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium mb-1" style="color: var(--color-text-primary);">Email</label>
            <input type="email" id="email" name="email" required class="form-input w-full px-4 py-2.5 rounded-lg border transition-colors" autocomplete="email" />
          </div>
          <div>
            <label for="phone" class="block text-sm font-medium mb-1" style="color: var(--color-text-primary);">Phone (optional)</label>
            <input type="tel" id="phone" name="phone" class="form-input w-full px-4 py-2.5 rounded-lg border transition-colors" autocomplete="tel" inputmode="tel" />
          </div>
          <div>
            <label for="project-type" class="block text-sm font-medium mb-1" style="color: var(--color-text-primary);">Project Type</label>
            <select id="project-type" name="project_type" class="form-input w-full px-4 py-2.5 rounded-lg border transition-colors">
              <option value="">Select a project type</option>
              <option value="bathroom">Bathroom Remodel</option>
              <option value="flooring">Flooring Installation</option>
              <option value="backsplash">Backsplash Installation</option>
              <option value="shower">Custom Shower</option>
              <option value="other">Other</option>
            </select>
          </div>
          <div>
            <label for="message" class="block text-sm font-medium mb-1" style="color: var(--color-text-primary);">Project Details</label>
            <textarea id="message" name="message" rows="4" class="form-input w-full px-4 py-2.5 rounded-lg border transition-colors" placeholder="Describe your project scope, timeline, and any questions..."></textarea>
          </div>
          <input type="hidden" name="source" value="tillerstead" />
          <button type="submit" class="w-full px-6 py-3 rounded-lg text-white font-medium transition-opacity hover:opacity-90" style="background-color: var(--color-brand-primary);">
            Send Request
          </button>
          <p class="text-xs text-center" style="color: var(--color-text-tertiary);">We respond within one business day. Your information is never shared.</p>
        </form>
      </div>

    </div>
  </div>
</section>