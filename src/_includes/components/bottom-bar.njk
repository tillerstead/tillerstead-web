{#- Unified Bottom Action Bar — Responsive sticky CTA -#}
<aside class="ts-bottom-bar" id="bottom-bar" aria-label="Quick actions" hidden>
  {#- Mobile: compact 4-button bar -#}
  <div class="ts-bottom-bar__mobile">
    <a href="tel:+16098628808" class="ts-bottom-bar__btn ts-bottom-bar__btn--call" aria-label="Call us">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
      <span>Call</span>
    </a>
    <a href="sms:+16098628808" class="ts-bottom-bar__btn ts-bottom-bar__btn--text" aria-label="Text us">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
      <span>Text</span>
    </a>
    <a href="/contact/" class="ts-bottom-bar__btn ts-bottom-bar__btn--quote" aria-label="Get a quote">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
      <span>Quote</span>
    </a>
    <button type="button" class="ts-bottom-bar__btn ts-bottom-bar__btn--top" aria-label="Back to top" id="back-to-top-btn">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 19V5"/><path d="M5 12l7-7 7 7"/></svg>
      <span>Top</span>
    </button>
  </div>

  {#- Desktop: expanded CTA bar -#}
  <div class="ts-bottom-bar__desktop">
    <div class="ts-bottom-bar__content">
      <div class="ts-bottom-bar__message">
        <strong>Ready to transform your space?</strong>
        <span>Free estimates for South Jersey homeowners</span>
      </div>
      <div class="ts-bottom-bar__ctas">
        <a href="/contact/" class="ts-bottom-bar__cta ts-bottom-bar__cta--primary">
          Get Free Estimate
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
        </a>
        <a href="tel:+16098628808" class="ts-bottom-bar__cta ts-bottom-bar__cta--secondary">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          Call (609)&nbsp;862&#8209;8808
        </a>
      </div>
    </div>
    <button type="button" class="ts-bottom-bar__dismiss" aria-label="Dismiss" id="bottom-bar-dismiss">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
    </button>
  </div>
</aside>

