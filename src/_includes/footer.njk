{%- set footer_groups = navigation.footer -%}
<footer class="ts-footer" aria-label="Site Footer">
  <div class="footer-main">
    <!-- Logo Section -->
    <div class="footer-logo-section">
      <a href="/" aria-label="Tillerstead Home">
        <img src="/assets/img/logo/logo-optimized.png" alt="Tillerstead Logo" class="footer-logo" width="480" height="320" loading="lazy" />
      </a>
      <p class="footer-tagline">{{ site.tagline }}</p>
    </div>

    <!-- Footer Navigation Grid -->
    <div class="footer-sections">
      <!-- Service Areas - Full Width Top Row -->
      {%- set service_areas = footer_groups | where("group", "Service Areas") | first -%} {% if service_areas %}
      <div class="footer-group footer-group--service-areas">
        <h3 class="footer-group-title">{{ service_areas.group }}</h3>
        <ul class="footer-list footer-list--horizontal">
          {% for item in service_areas.items %}
          <li><a href="{{ item.url }}">{{ item.title }}</a></li>
          {% endfor %}
        </ul>
      </div>
      {% endif %}

      <!-- Learn Column -->
      {%- set learn_group = footer_groups | where("group", "Learn") | first -%} {% if learn_group %}
      <div class="footer-group footer-group--learn">
        <h3 class="footer-group-title">{{ learn_group.group }}</h3>
        <ul class="footer-list">
          {% for item in learn_group.items %}
          <li><a href="{{ item.url }}">{{ item.title }}</a></li>
          {% endfor %}
        </ul>
      </div>
      {% endif %}

      <!-- Build Guides Column -->
      {%- set build_group = footer_groups | where("group", "Build Guides") | first -%} {% if build_group %}
      <div class="footer-group footer-group--build-guides">
        <h3 class="footer-group-title">{{ build_group.group }}</h3>
        <ul class="footer-list footer-list--two-col">
          {% for item in build_group.items %}
          <li><a href="{{ item.url }}">{{ item.title }}</a></li>
          {% endfor %}
        </ul>
      </div>
      {% endif %}

      <!-- Company Column -->
      {%- set company_group = footer_groups | where("group", "Company") | first -%} {% if company_group %}
      <div class="footer-group footer-group--company">
        <h3 class="footer-group-title">{{ company_group.group }}</h3>
        <ul class="footer-list">
          {% for item in company_group.items %}
          <li><a href="{{ item.url }}">{{ item.title }}</a></li>
          {% endfor %}
        </ul>
      </div>
      {% endif %}
    </div>

    <!-- Contact Section -->
    <div class="footer-contact">
      <h3 class="footer-group-title">Contact</h3>
      <p class="footer-license">NJ HIC #{{ site.company.hic }}</p>
      <address class="footer-address">
        {{ site.company.address_line }}<br />
        {{ site.company.address_city }}, {{ site.company.address_region }} {{ site.company.address_postal_code }}
      </address>
      <p class="footer-contact-phone">
        <a href="tel:{{ site.company.phone_link }}">{{ site.company.phone_display }}</a>
      </p>
      <p class="footer-contact-email">
        <a href="mailto:{{ site.company.email }}">{{ site.company.email }}</a>
      </p>
    </div>

    <!-- Bottom Bar -->
    <div class="footer-bottom">
      <div class="footer-legal">
        <a href="/privacy/">Privacy</a>
        <span class="footer-divider">&middot;</span>
        <a href="/terms/">Terms</a>
        <span class="footer-divider">&middot;</span>
        <a href="/disclaimers/">Disclaimers</a>
        <span class="footer-divider">&middot;</span>
        <a href="/copyright/">Copyright</a>
      </div>
      <p class="footer-copyright">&copy; {{ 'now' | date("%Y") }} Tillerstead LLC. All rights reserved.</p>
      <p class="footer-trademark-text">
        Tillerstead&trade; and TillerPro&trade; are trademarks of Tillerstead LLC. Licensed, Bonded &amp; Insured. NJ HIC #{{ site.company.hic }}.
      </p>
    </div>
  </div>
</footer>
