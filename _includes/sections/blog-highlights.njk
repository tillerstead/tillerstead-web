{# Homepage Blog Highlights Include - Renders recent N posts as compact cards - Params: limit (default 3),
eyebrow, title, summary, cta_url, cta_label Usage: {% include "content/blog-highlights.njk" %} #}
{%- set posts_sorted = collections.posts | sort_by("date") | reverse -%} {%- set limit = limit | default(3) -%} {%- set items = posts_sorted | slice(0, limit) -%} {% if items and items.length > 0 %} {%- set section_id = section_id | default("home-blog") -%} {% set heading_id = heading_id | default(section_id) + "-title" %}
<section class="ts-section section blog" aria-labelledby="{{ heading_id }}">
  <div class="container">
    <div class="section-header">
      <p class="eyebrow text-accent">{{ eyebrow | default("Tile & Remodeling Insights") }}</p>
      <h2 id="{{ heading_id }}" class="heading-2">{{ title | default("Latest Contractor Articles") }}</h2>
      <p class="lead">
        {{ summary | default("Technical guidance on TCNA 2024-compliant tile installation, ANSI A108.10
        waterproofing, and code-compliant bathroom remodeling for South Jersey homeowners. New Jersey HIC
        #13VH10808800.") }}
      </p>
    </div>

    <ul class="cards cards--3col" role="list" aria-label="Latest contractor articles">
      {% for post in items %}
      <li class="card card--post" itemscope itemtype="https://schema.org/Article">
        <h3 class="card-title heading-4" itemprop="headline">
          <a href="{{ post.url | relative_url }}" itemprop="url">{{ post.title }}</a>
        </h3>
        <p class="card-meta">
          <time datetime="{{ post.date | date_to_xmlschema }}" itemprop="datePublished">
            {{ post.date | date("%B %e, %Y") }}
          </time>
        </p>
        {% if post.description %}
        <p class="card-desc" itemprop="description">{{ post.description }}</p>
        {% else %}
        <p class="card-desc" itemprop="description">{{ post.excerpt | strip_html | truncate(140) }}</p>
        {% endif %}
        <p>
          <a class="card-link" href="{{ post.url | relative_url }}" aria-label="Read article: {{ post.title }}">
            Read full article – TCNA standards, New Jersey HIC compliance
          </a>
        </p>
      </li>
      {% endfor %}
    </ul>

    <div class="section-action">
      <a
        href="{{ cta_url | default("/blog/") | relative_url }}"
        class="btn btn--primary"
        aria-label="View all contractor articles"
      >
        {{ cta_label | default("Browse all contractor articles") }}
      </a>
    </div>
  </div>
</section>
{% endif %}
