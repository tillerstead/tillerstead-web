---
layout: false
title: Early Access - Tillerstead LLC
description: Coming soon. Request early access to Tillerstead services.
meta_description: Tillerstead LLC - Coming Soon. Contract remodeling services for bathrooms, flooring, backsplash, and interior demo plus install.
permalink: /early-access/index.html
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="{{ meta_description }}" />
  <meta name="theme-color" content="#0a6840" />
  <title>{{ title }}</title>
  
  <link rel="stylesheet" href="/assets/css/tokens.css" />
  <link rel="stylesheet" href="/assets/css/base.css" />
  <link rel="stylesheet" href="/assets/css/utilities.css" />
  
  <style>
    .coming-soon-grid {
      position: fixed;
      inset: 0;
      opacity: 0.03;
      z-index: -1;
    }
    
    .coming-soon-orb {
      position: fixed;
      border-radius: 50%;
      filter: blur(120px);
      z-index: -1;
      animation: float 20s ease-in-out infinite;
    }

    .orb-1 {
      width: 300px;
      height: 300px;
      top: 10%;
      right: 10%;
      background: radial-gradient(ellipse at center, rgba(217, 119, 6, 0.3), transparent);
      animation-delay: 0s;
    }

    .orb-2 {
      width: 250px;
      height: 250px;
      bottom: 10%;
      left: 5%;
      background: radial-gradient(ellipse at center, rgba(217, 119, 6, 0.2), transparent);
      animation-delay: 5s;
    }

    @keyframes float {
      0%, 100% { transform: translate(0, 0); }
      33% { transform: translate(30px, -30px); }
      66% { transform: translate(-20px, 20px); }
    }

    @media (prefers-reduced-motion: reduce) {
      .coming-soon-orb {
        animation: none;
      }
    }
  </style>
</head>

<body style="background-color: var(--color-surface-secondary); color: var(--color-text-primary);">
  
  {# Decorative backgrounds #}
  <div class="coming-soon-orb orb-1"></div>
  <div class="coming-soon-orb orb-2"></div>
  <svg class="coming-soon-grid" viewBox="0 0 1000 1000">
    <defs>
      <pattern id="grid" x="0" y="0" width="50" height="50" patternUnits="userSpaceOnUse">
        <rect x="0" y="0" width="50" height="50" fill="none" stroke="currentColor" stroke-width="0.5"/>
      </pattern>
    </defs>
    <rect width="100%" height="100%" fill="url(#grid)"/>
  </svg>

  {# Header #}
  <header class="sticky top-0 z-40 shadow-sm" style="background-color: var(--color-surface-primary); border-bottom: 1px solid var(--color-border-primary);">
    <div class="mx-auto max-w-6xl px-6 py-4">
      <a href="/" class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-lg flex items-center justify-center" style="background: linear-gradient(135deg, var(--color-brand-primary), var(--color-brand-primary-dark));">
          <span class="text-white font-bold text-lg">T</span>
        </div>
        <div>
          <div class="font-semibold" style="color: var(--color-text-primary);">Tillerstead</div>
          <div class="text-xs" style="color: var(--color-text-tertiary);">LLC</div>
        </div>
      </a>
    </div>
  </header>

  <main class="min-h-screen flex items-center py-16">
    <div class="mx-auto max-w-2xl px-6 w-full">
      
      {# Hero Content #}
      <div class="text-center mb-12">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-sm font-medium mb-6" style="background-color: var(--color-brand-primary-tint); border: 1px solid var(--color-brand-primary-border); color: var(--color-brand-primary);">
          <span class="w-1.5 h-1.5 rounded-full" style="background-color: var(--color-brand-primary);"></span>
          Rebuilding for Service
        </div>
        
        <h1 class="text-4xl md:text-5xl font-bold mb-6 leading-tight" style="color: var(--color-text-primary);">
          Coming Soon to <span style="color: var(--color-brand-primary);">New Jersey</span>
        </h1>
        
        <p class="text-lg max-w-xl mx-auto mb-4" style="color: var(--color-text-secondary);">
          Tillerstead LLC is preparing to reopen with contract remodeling scopes focused on bathrooms, flooring, backsplash, selective demolition, and finish installs.
        </p>
        
        <p class="mb-12" style="color: var(--color-text-tertiary);">
          <strong>Currently rebuilding:</strong> truck, equipment, insurance, and HIC license. Early access available by request.
        </p>
      </div>

      {# Early Access Form #}
      <div class="rounded-xl border shadow-sm p-8 mb-12" style="background-color: var(--color-surface-primary); border-color: var(--color-border-primary);">
        <h2 class="text-2xl font-semibold mb-6" style="color: var(--color-text-primary);">Request Early Access</h2>
        
        <form id="earlyAccessForm" class="space-y-4">
          
          <div>
            <label for="name" class="block text-sm font-medium mb-1" style="color: var(--color-text-primary);">
              Full Name <span style="color: var(--color-error);">*</span>
            </label>
            <input 
              type="text" 
              id="name" 
              name="name"
              required
              class="form-input w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:border-transparent"
              placeholder="John Smith"
            />
          </div>

          <div>
            <label for="email" class="block text-sm font-medium mb-1" style="color: var(--color-text-primary);">
              Email <span style="color: var(--color-error);">*</span>
            </label>
            <input 
              type="email" 
              id="email" 
              name="email"
              required
              class="form-input w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:border-transparent"
              placeholder="john@example.com"
            />
          </div>

          <div>
            <label for="phone" class="block text-sm font-medium mb-1" style="color: var(--color-text-primary);">
              Phone <span style="color: var(--color-error);">*</span>
            </label>
            <input 
              type="tel" 
              id="phone" 
              name="phone"
              required
              class="form-input w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:border-transparent"
              placeholder="(201) 555-0100"
            />
          </div>

          <div>
            <label for="projectType" class="block text-sm font-medium mb-1" style="color: var(--color-text-primary);">
              Project Type <span style="color: var(--color-error);">*</span>
            </label>
            <select 
              id="projectType" 
              name="projectType"
              required
              class="form-input w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:border-transparent"
            >
              <option value="">Select a project type</option>
              <option value="bathroom-remodel">Bathroom Remodel</option>
              <option value="flooring-install">Flooring Install</option>
              <option value="backsplash-install">Kitchen Backsplash</option>
              <option value="demo-prep">Selective Demo and Prep</option>
              <option value="interior-finish">Interior Finish Install</option>
              <option value="other">Other</option>
            </select>
          </div>

          <div>
            <label for="message" class="block text-sm font-medium mb-1" style="color: var(--color-text-primary);">
              Tell us about your project
            </label>
            <textarea 
              id="message" 
              name="message"
              rows="4"
              class="form-input w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:border-transparent resize-none"
              placeholder="Describe your project and what you're looking for..."
            ></textarea>
          </div>

          <div class="flex items-start gap-3">
            <input 
              type="checkbox" 
              id="consent" 
              name="consent"
              required
              class="mt-1"
            />
            <label for="consent" class="text-sm" style="color: var(--color-text-secondary);">
              I agree to be contacted about early access and project inquiries.
            </label>
          </div>

          <button 
            type="submit"
            class="w-full px-6 py-3 mt-6 text-white font-semibold rounded-lg transition-opacity hover:opacity-90"
            style="background-color: var(--color-brand-primary);"
          >
            Request Early Access
          </button>

        </form>

        <p class="text-xs mt-4 text-center" style="color: var(--color-text-tertiary);">
          We'll be in touch within 24 hours. Your information will not be shared.
        </p>
      </div>

      {# Why Early Access #}
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
        
        <div class="text-center">
          <div class="inline-flex items-center justify-center w-12 h-12 rounded-full mb-4" style="background-color: var(--color-brand-primary-tint); color: var(--color-brand-primary);">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="font-semibold mb-2" style="color: var(--color-text-primary);">Priority Service</h3>
          <p class="text-sm" style="color: var(--color-text-secondary);">Early access users get priority scheduling and special attention on their projects.</p>
        </div>

        <div class="text-center">
          <div class="inline-flex items-center justify-center w-12 h-12 rounded-full mb-4" style="background-color: var(--color-brand-primary-tint); color: var(--color-brand-primary);">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="font-semibold mb-2" style="color: var(--color-text-primary);">Special Pricing</h3>
          <p class="text-sm" style="color: var(--color-text-secondary);">Early supporters may receive special introductory rates and discounts.</p>
        </div>

        <div class="text-center">
          <div class="inline-flex items-center justify-center w-12 h-12 rounded-full mb-4" style="background-color: var(--color-brand-primary-tint); color: var(--color-brand-primary);">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="font-semibold mb-2" style="color: var(--color-text-primary);">Expert Input</h3>
          <p class="text-sm" style="color: var(--color-text-secondary);">Your feedback helps shape our services to better meet your needs.</p>
        </div>

      </div>

    </div>
  </main>

  {# Footer #}
  <footer style="background-color: var(--color-surface-dark); color: var(--color-text-inverse); border-top: 1px solid var(--color-border-inverse);">
    <div class="mx-auto max-w-6xl px-6 py-8">
      <div class="flex flex-col md:flex-row items-center justify-between gap-4 text-sm" style="color: var(--color-text-inverse-tertiary);">
        <p>&copy; 2026 Tillerstead LLC. All rights reserved.</p>
        <div class="flex gap-4">
          <a href="/privacy/" class="footer-link">Privacy</a>
          <a href="/terms/" class="footer-link">Terms</a>
          <a href="/" class="footer-link">Home</a>
        </div>
      </div>
    </div>
  </footer>

  <script>
    // Simple form submission handler
    const form = document.getElementById('earlyAccessForm');
    if (form) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const name = document.getElementById('name').value;
        const email = document.getElementById('email').value;
        
        // Simple confirmation
        alert(`Thank you, ${name}! We'll contact you at ${email} soon.`);
        form.reset();
      });
    }
  </script>

</body>
</html>
