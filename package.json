{
  "name": "tillerstead-com",
  "private": true,
  "version": "1.0.0",
  "description": "Tillerstead - Premium Tile & Waterproofing Contractor Website",
  "author": "DTB396",
  "license": "UNLICENSED",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/tillerstead/tillerstead-web.git"
  },
  "scripts": {
    "build": "npx @11ty/eleventy --input=src",
    "build:prod": "npm run minify:all && npm run critical:css && npm run minify:html && npx @11ty/eleventy --input=src",
    "dev": "npx @11ty/eleventy --input=src --serve",
    "serve:test": "npx @11ty/eleventy --input=src --serve --port=4173",
    "export:resources": "echo \"export:resources requires resource-bridge vendoring; skipping in standalone mode\"",
    "clean": "pwsh -Command \"Remove-Item -Recurse -Force _site -ErrorAction SilentlyContinue\"",
    "lint": "npm run lint:js && npm run lint:css",
    "lint:js": "eslint assets/js/",
    "lint:css": "stylelint \"assets/css/**/*.css\"",
    "lint:html": "html-validate \"_site/**/*.html\" --config .htmlvalidate.json",
    "lint:fix": "npm run lint:js -- --fix && npm run lint:css -- --fix && npm run format",
    "format": "prettier --write \"**/*.{js,css,html,md,json}\"",
    "format:check": "prettier --check \"**/*.{js,css,html,md,json}\"",
    "test": "echo \"Tillerstead E2E tests require Playwright browsers — run test:nav locally\"",
    "test:domain": "node scripts/standalone/domain-check.cjs",
    "test:api": "node scripts/standalone/http-check.cjs",
    "test:smoke": "node scripts/standalone/smoke-check.cjs",
    "health": "npx tsx src/health.ts",
    "test:e2e": "npm run test:nav",
    "test:nav": "playwright test tests/navigation.spec.js",
    "test:nav:headed": "playwright test tests/navigation.spec.js --headed",
    "test:nav:debug": "playwright test tests/navigation.spec.js --debug",
    "test:nav:mobile": "playwright test tests/navigation.spec.js --project=mobile-chrome-iphone-16-pro-max",
    "optimize": "node scripts/optimize-repo.js",
    "optimize:logos": "node scripts/optimize-logo-system.js",
    "optimize:images": "node scripts/optimize-images.js",
    "scan:links": "node scripts/scan-links.js",
    "minify:css": "cleancss -o assets/css/bundle.min.css assets/css/vendor-integrations.css assets/css/root-vars.css assets/css/modern/modern.css assets/css/ux-enhancements.css",
    "minify:js": "terser assets/js/vendor-init.js assets/js/navigation-system.js assets/js/main.js assets/js/ux-enhancements.js -o assets/js/bundle.min.js --compress --mangle",
    "minify:html": "node scripts/minify-html.js",
    "minify:all": "npm run minify:css && npm run minify:js",
    "bundle:css": "concat-cli -f assets/css/vendor-integrations.css assets/css/root-vars.css assets/css/modern/modern.css assets/css/ux-enhancements.css -o assets/css/bundle.css",
    "bundle:js": "concat-cli -f assets/js/vendor-init.js assets/js/navigation-system.js assets/js/main.js assets/js/ux-enhancements.js -o assets/js/bundle.js",
    "critical:css": "node scripts/extract-critical-css.js",
    "critical:inline": "critical https://tillerstead.com --inline --base _site",
    "sw:generate": "workbox generateSW workbox-config.cjs",
    "sw:inject": "workbox injectManifest workbox-config.cjs",
    "lighthouse": "lighthouse https://tillerstead.com --output html --output-path ./lighthouse-report.html --view",
    "lighthouse:local": "lighthouse http://localhost:4000 --output html --output-path ./lighthouse-local.html --view",
    "analyze": "npm run lighthouse && npm run scan:links && npm run optimize",
    "analyze:size": "size-limit",
    "analyze:css": "purgecss --css assets/css/**/*.css --content _site/**/*.html --output assets/css/purged/",
    "perf:vitals": "node scripts/web-vitals-monitor.js",
    "perf:report": "node scripts/performance-report.js",
    "perf:check": "node scripts/performance-check.js",
    "site:repair": "node scripts/site-repair-tool.js",
    "seo:audit": "node scripts/seo-audit.js",
    "images:webp": "node scripts/convert-to-webp.js",
    "images:avif": "node scripts/convert-to-avif.js",
    "images:optimize": "npm run images:webp && npm run images:avif && node scripts/optimize-images.js",
    "unused:css": "purgecss --css assets/css/**/*.css --content _site/**/*.html --output assets/css/purged/",
    "unused:detect": "node scripts/detect-unused.js",
    "validate:svg": "node scripts/validate-svg-viewbox.mjs",
    "validate:html": "html-validate \"_site/**/*.html\"",
    "security:audit": "npm audit --production",
    "precommit": "npm run format && npm run validate:html && npm run test",
    "postbuild": "npm run optimize:images",
    "automate": "node scripts/content-automation.js",
    "automate:schedule": "node scripts/content-automation.js schedule",
    "automate:social": "node scripts/content-automation.js social",
    "automate:newsletter": "node scripts/content-automation.js newsletter",
    "automate:analytics": "node scripts/content-automation.js analytics",
    "check:ux": "node scripts/quick-error-check.js",
    "check:a11y": "pa11y-ci",
    "check:perf": "sitespeed.io https://tillerstead.com",
    "fix:ux": "npm run check:ux && npm run build",
    "verify:ux": "node scripts/verify-ux-files.js",
    "test:ux": "npm run verify:ux && npx @11ty/eleventy --input=src && npx @11ty/eleventy --input=src --serve",
    "dev:local": "node scripts/devserver.js --open",
    "dev:local:nobrowser": "node scripts/devserver.js",
    "verify": "node scripts/standalone/verify-build.cjs _site"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.9.7"
  },
  "devDependencies": {
    "@11ty/eleventy": "3.1.5",
    "@11ty/eleventy-plugin-rss": "3.0.0",
    "@playwright/test": "^1.59.1",
    "aos": "2.3.4",
    "autoprefixer": "10.4.27",
    "cheerio": "1.2.0",
    "clean-css-cli": "^5.6.3",
    "concat-cli": "4.0.0",
    "critical": "7.2.1",
    "cssnano": "7.1.5",
    "cssnano-preset-advanced": "7.0.12",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "fast-xml-parser": "5.7.0",
    "globals": "14.0.0",
    "html-minifier-terser": "7.2.0",
    "html-validate": "10.13.1",
    "husky": "^9.1.7",
    "js-yaml": "^4.1.1",
    "lenis": "1.3.18",
    "lighthouse": "^12.2.1",
    "luxon": "3.7.2",
    "markdown-it": "14.1.1",
    "modern-normalize": "3.0.1",
    "open-props": "1.7.23",
    "pa11y": "9.1.1",
    "postcss": "8.5.13",
    "postcss-cli": "^11.0.0",
    "postcss-import": "16.1.1",
    "postcss-jit-props": "1.0.16",
    "postcss-nesting": "14.0.0",
    "postcss-preset-env": "10.6.1",
    "prettier": "3.8.3",
    "puppeteer": "24.39.0",
    "purgecss": "^6.0.0",
    "sharp": "^0.33.5",
    "size-limit": "12.0.1",
    "stylelint": "17.4.0",
    "stylelint-config-standard": "^36.0.1",
    "stylelint-config-standard-scss": "^14.0.0",
    "stylelint-scss": "^6.0.0",
    "svgo": "4.0.1",
    "terser": "^5.36.0",
    "web-vitals": "5.3.0",
    "workbox-cli": "7.4.0",
    "@eslint/js": "^9.0.0"
  },
  "overrides": {
    "serialize-javascript": "7.0.5",
    "fast-uri": "3.1.2",
    "fast-xml-builder": "1.2.0",
    "brace-expansion": "1.1.14"
  }
}
