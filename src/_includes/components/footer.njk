          <li><a href="/services/#demo" class="footer-link hover:text-white transition-colors">Demo and Prep</a></li>
        </ul>
      </div>
      {# Guides #}
      <div>
        <h4 class="font-semibold mb-4 text-sm uppercase tracking-wide">Guides</h4>
        <ul class="space-y-2 text-sm" role="list">
          <li><a href="/guides/" class="footer-link hover:text-white transition-colors">All Guides</a></li>
          <li><a href="/guides/renovation/" class="footer-link hover:text-white transition-colors">Renovation Guides</a></li>
          <li><a href="/guides/repairs/" class="footer-link hover:text-white transition-colors">Repair Guides</a></li>
          <li><a href="/build/" class="footer-link hover:text-white transition-colors">Build Phases</a></li>
