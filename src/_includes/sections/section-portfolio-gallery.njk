<section class="portfolio-gallery">
  <div class="container">
    <!-- Filter Buttons -->
    <nav class="portfolio-filters" role="navigation" aria-label="Portfolio filters">
      <button class="filter-btn active" data-filter="all" aria-label="Show all projects">All Projects</button>
      <button class="filter-btn" data-filter="showers" aria-label="Filter by showers">Showers</button>
      <button class="filter-btn" data-filter="floors" aria-label="Filter by floors">Floors</button>
      <button class="filter-btn" data-filter="backsplash" aria-label="Filter by backsplash">Backsplash</button>
      <button class="filter-btn" data-filter="large-format" aria-label="Filter by large-format tile">
        Large-Format
      </button>
      <button class="filter-btn" data-filter="prep" aria-label="Filter by prep and waterproofing">Prep</button>
    </nav>

    <!-- Project Grid -->
    <div class="project-grid ts-portfolio-tiled" role="region" aria-live="polite">
      {%- set projects = portfolio.projects | sort_by("priority") | reverse -%} {% for project in projects %}
      <article class="project-card" data-tags="{{ project.tags | join(' ') }}">
        <div class="project-image">
          <img src="{{ project.file }}" alt="{{ project.alt }}" loading="lazy" />
        </div>
        <div class="project-content">
          <h3 class="project-title">{{ project.title }}</h3>
          <p class="project-caption">{{ project.caption }}</p>
          {% if project.tags %}
          <div class="project-tags">
            {% for tag in project.tags %}
            <span class="tag">{{ tag }}</span>
            {% endfor %}
          </div>
          {% endif %}
        </div>
      </article>
      {% endfor %}
    </div>

    <!-- Compliance Note -->
    <div class="portfolio-note">
      <p>{{ portfolio.meta.compliance_note }}</p>
    </div>
  </div>
</section>
